   DEF_forcing%startmo           = 10        ! start month of forcing data
   DEF_forcing%endyr             = 2010    ! end year of forcing data
   DEF_forcing%endmo             = 9       ! end month of forcing data
   
   DEF_forcing%fprefix(1) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(2) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(3) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(4) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(5) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(6) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(7) = 'met_insitu_obs_1997_2010.nc'
   DEF_forcing%fprefix(8) = 'met_insitu_obs_1997_2010.nc'
   
   DEF_forcing%vname    = 'Tair' 'Qair' 'Psurf' 'Rainf' 'NULL' 'Wind' 'SWdown' 'LWdown' 
   DEF_forcing%tintalgo = 'linear' 'linear' 'linear' 'nearest' 'NULL' 'linear' 'coszen' 'linear'

