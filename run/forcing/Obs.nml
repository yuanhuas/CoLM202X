&nl_colm_forcing

   ! ----- forcing -----
   DEF_dir_forcing  = '/stu01/dongwz/data/inputdata/single_point/vegsnow/'

   DEF_forcing%dataset           = 'POINT' 
   DEF_forcing%solarin_all_band  = .true.  
   DEF_forcing%HEIGHT_V          = 26   
   DEF_forcing%HEIGHT_T          = 25
   DEF_forcing%HEIGHT_Q          = 25
   
   DEF_forcing%NVAR              = 8        ! variable number of forcing data
