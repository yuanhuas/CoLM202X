&nl_colm_rawdata

  !==========================================================================!
  ! FORMAT: For each data type, set idx (1-10) to choose the active
  !         dataset from opt(1:10). Unused opt entries may be left
  !         as default or set to 'null'.
  !==========================================================================!

  !--------------------------------------------------------------------------!
  ! 1. Land cover and land use data
  !--------------------------------------------------------------------------!
  ! Options:
  !   1: USGS 1km, xxx
  !   2: MODIS IGBP 500m, xxx
  !   3: ESA-CCI 500m, xxx
  !   4: GLC30 30m, xxx
  DEF_rawdata_nml%landcover%idx = 2

  DEF_rawdata_nml%landcover%opt(1)%dir   = '/landcover/usgs/'
  DEF_rawdata_nml%landcover%opt(1)%gname = 'colm_1km'
  DEF_rawdata_nml%landcover%opt(1)%fname = 'landtype-usgs-update'

  DEF_rawdata_nml%landcover%opt(2)%dir   = '/landcover/modis/'
  DEF_rawdata_nml%landcover%opt(2)%gname = 'colm_500m'
  DEF_rawdata_nml%landcover%opt(2)%fname = 'LC500m.modis_igbp'

  DEF_rawdata_nml%landcover%opt(3)%dir   = '/landcover/esa/'
  DEF_rawdata_nml%landcover%opt(3)%gname = 'colm_500m'
  DEF_rawdata_nml%landcover%opt(3)%fname = 'ESACCI'

  DEF_rawdata_nml%landcover%opt(4)%dir   = '/landcover/glc/'
  DEF_rawdata_nml%landcover%opt(4)%gname = 'colm_30m'
  DEF_rawdata_nml%landcover%opt(4)%fname = 'LC30m.GLC'

  !--------------------------------------------------------------------------!
  ! 2. Vegetation data
  !--------------------------------------------------------------------------!

  ! ----- PFT fraction data -----
  ! Options:
  !   1: c2022 500m
  !   2: c2025 500m
  !   3: c2025 30m
  DEF_rawdata_nml%pft%idx = 1

  DEF_rawdata_nml%pft%opt(1)%dir   = '/vegetation_pft/c2022/'
  DEF_rawdata_nml%pft%opt(1)%gname = 'colm_500m'
  DEF_rawdata_nml%pft%opt(1)%fname = 'PFT500m'

  DEF_rawdata_nml%pft%opt(2)%dir   = '/vegetation_pft/c2025/'
  DEF_rawdata_nml%pft%opt(2)%gname = 'colm_500m'
  DEF_rawdata_nml%pft%opt(2)%fname = 'PFT500m'

  DEF_rawdata_nml%pft%opt(3)%dir   = '/vegetation_pft/c2025/'
  DEF_rawdata_nml%pft%opt(3)%gname = 'colm_30m'
  DEF_rawdata_nml%pft%opt(3)%fname = 'PFT30m'

  ! ----- LAI and SAI data -----
  ! Options:
  !   1: c2022 500m
  !   2: c2025 500m
  !   3: c2025_snowfree 500m
  DEF_rawdata_nml%lai_sai%idx = 1

  DEF_rawdata_nml%lai_sai%opt(1)%dir   = '/vegetation_lai_sai/c2022/'
  DEF_rawdata_nml%lai_sai%opt(1)%gname = 'colm_500m'
  DEF_rawdata_nml%lai_sai%opt(1)%fname = 'LSAI500m'

  DEF_rawdata_nml%lai_sai%opt(2)%dir   = '/vegetation_lai_sai/c2025/'
  DEF_rawdata_nml%lai_sai%opt(2)%gname = 'colm_500m'
  DEF_rawdata_nml%lai_sai%opt(2)%fname = 'LSAI500m'

  DEF_rawdata_nml%lai_sai%opt(3)%dir   = '/vegetation_lai_sai/c2025_snowfree/'
  DEF_rawdata_nml%lai_sai%opt(3)%gname = 'colm_500m'
  DEF_rawdata_nml%lai_sai%opt(3)%fname = 'LSAI500m'

  ! ----- tree top height data -----
  ! Options:
  !   1: Simard 1km
  !   2: ETH 500m
  !   3: ETH 30m
  !   4: Tolan 500m
  !   5: Tolan 30m
