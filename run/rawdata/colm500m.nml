  DEF_rawdata_nml%htop%opt(4)%fname = 'Htop500m.Tolan'
  DEF_rawdata_nml%htop%opt(4)%vname = 'HTOP_90'

  DEF_rawdata_nml%htop%opt(5)%dir   = '/vegetation_morphology/tree_height_Tolan/'
  DEF_rawdata_nml%htop%opt(5)%gname = 'colm_30m'
  DEF_rawdata_nml%htop%opt(5)%fname = 'Htop30m.Tolan'
  DEF_rawdata_nml%htop%opt(5)%vname = 'HTOP'

  !--------------------------------------------------------------------------!
  ! 3. Soil data
  !--------------------------------------------------------------------------!
  !TODO: options can be extended below
  DEF_rawdata_nml%soil%opt(1)%dir = '/soil/'

  !--------------------------------------------------------------------------!
  ! 4. Topographic data
  !--------------------------------------------------------------------------!
  DEF_rawdata_nml%topo%opt(1)%dir = '/topography/'

  !--------------------------------------------------------------------------!
  ! 5. Hydrological data
  !--------------------------------------------------------------------------!
  DEF_rawdata_nml%hydro%opt(1)%dir = '/hydrology/'

  !--------------------------------------------------------------------------!
  ! 6. Water Resources
  !--------------------------------------------------------------------------!
  DEF_rawdata_nml%water%opt(1)%dir = '/water_resource/'

  !--------------------------------------------------------------------------!
