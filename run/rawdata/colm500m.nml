  !--------------------------------------------------------------------------!

  ! ----- Urban subgrid type -----
  ! Options:
  !   1: NCAR 1km
  !   2: LCZ 500m
  !   3: LCZ 100m
  DEF_rawdata_nml%urban_type%idx = 2

  DEF_rawdata_nml%urban_type%opt(1)%dir   = '/urban_type/ncar/'
  DEF_rawdata_nml%urban_type%opt(1)%gname = 'colm_500m'
